{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "genai": {
      "description": "Agente de investigación genealógica familiar. Usa IA para expandir árboles, auditar fuentes, analizar ADN y gestionar un vault de Obsidian.",
      "mode": "primary",
      "model": "opencode/big-pickle",
      "prompt": "{file:./agents/genai.md}",
      "tools": {
        "bash": true,
        "edit": true,
        "read": true,
        "write": true,
        "webfetch": true,
        "websearch": true,
        "delegate": true,
        "task": true
      }
    }
  },
  "skills": {
    "paths": ["./skills"]
  }
}
